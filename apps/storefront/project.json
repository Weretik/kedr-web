{
  "name": "storefront",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/storefront/src",
  "i18n": {
    "sourceLocale": "uk",
    "locales": {
      "ru": {
        "translation": [
          "apps/storefront/src/locale/messages.ru.xlf",
          "apps/storefront/src/locale/messages.ru.catalog.xlf",
          "apps/storefront/src/locale/messages.ru.footer.xlf",
          "apps/storefront/src/locale/messages.ru.about-company.xlf"
        ]
      }
    }
  },
  "tags": ["scope:storefront"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/storefront",
        "browser": "apps/storefront/src/main.ts",
        "polyfills": ["zone.js", "@angular/localize/init"],
        "tsConfig": "apps/storefront/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/storefront/public"
          }
        ],
        "styles": ["apps/storefront/src/styles.css"],
        "server": "apps/storefront/src/main.server.ts",
        "ssr": {
          "entry": "apps/storefront/src/server.ts"
        },
        "outputMode": "server"
      },
      "configurations": {
        "production": {
          "localize": ["uk", "ru"],
          "fileReplacements": [
            {
              "replace": "apps/storefront/src/environments/environment.ts",
              "with": "apps/storefront/src/environments/environment.production.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "900kb",
              "maximumError": "2mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "localize": ["uk", "ru"],
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "storefront:build:production"
        },
        "development": {
          "buildTarget": "storefront:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "storefront:build",
        "format": "xlf",
        "outputPath": "apps/storefront/src/locale",
        "outFile": "messages.xlf"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "storefront:build",
        "staticFilePath": "dist/apps/storefront/browser",
        "spa": false
      }
    },
    "build-cloudflare": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx nx build storefront",
          "copy /Y apps\\storefront\\public\\_redirects dist\\apps\\storefront\\browser\\_redirects"
        ],
        "parallel": false
      }
    }
  }
}
